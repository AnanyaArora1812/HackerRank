def separateNumbers(s):
    for i in range(1, len(s) // 2 + 1):
        first = int(s[:i])
        current = first
        formed = ""

        while len(formed) < len(s):
            formed += str(current)
            current += 1

        if formed == s:
            print(f"YES {first}")
            return

    print("NO")


q = int(input())

for _ in range(q):
    s = input().strip()
    separateNumbers(s)
